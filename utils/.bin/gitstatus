#!/usr/bin/env bash
# Show git status for all repos in a directory
# Usage: gitstatus           # Check subdirectories of current dir
#        gitstatus --fetch   # Fetch all remotes before checking

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

DO_FETCH=0
DIR="."

usage() {
    echo "Usage: gitstatus [OPTIONS] [DIRECTORY]"
    echo ""
    echo "Options:"
    echo "  -f, --fetch    Run 'git fetch' on all repos before checking"
    echo "  -h, --help     Show this help"
    exit 0
}

# Parse args
while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--fetch) DO_FETCH=1; shift ;;
        -h|--help)  usage ;;
        -*)         echo "Unknown option: $1"; usage ;;
        *)          DIR="$1"; shift ;;
    esac
done

check_repo() {
    local repo="$1"
    local name=$(basename "$repo")

    # Use a subshell to avoid needing to cd back
    (
        cd "$repo" 2>/dev/null || return

        # Check if it's a git repo
        if ! git rev-parse --git-dir &>/dev/null; then
            return
        fi

        # Optional fetch
        if [[ $DO_FETCH -eq 1 ]]; then
            printf "  ${BLUE}%-20s${NC} Fetching...\r" "$name"
            git fetch --quiet --parallel=4 2>/dev/null || true
        fi

        # Get status info
        local branch=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)
        local status=$(git status --porcelain 2>/dev/null)
        local ahead_behind=$(git rev-list --left-right --count @{upstream}...HEAD 2>/dev/null || echo "0 0")
        local behind=$(echo "$ahead_behind" | awk '{print $1}')
        local ahead=$(echo "$ahead_behind" | awk '{print $2}')

        # Build status string
        local state=""
        [[ -n "$status" ]] && state+="${YELLOW}*${NC}"  # Dirty
        [[ "$ahead" -gt 0 ]] && state+="${GREEN}+${ahead}${NC}"  # Ahead
        [[ "$behind" -gt 0 ]] && state+="${RED}-${behind}${NC}"  # Behind
        [[ -z "$state" ]] && state="${GREEN}ok${NC}"

        printf "  ${BLUE}%-20s${NC} %-15s %b\n" "$name" "($branch)" "$state"
    )
}

echo -e "${BLUE}Git repositories in ${DIR}:${NC}"
echo ""

# Find git repos (max depth 2 from DIR)
# DIR/repo/.git (depth 2) or DIR/group/repo/.git (depth 3)
found=0
while IFS= read -r -d '' d; do
    repo=$(dirname "$d")
    check_repo "$repo"
    found=1
done < <(find "$DIR" -maxdepth 3 -name ".git" -type d -print0 2>/dev/null)

if [[ $found -eq 0 ]]; then
    echo "  No git repositories found"
fi

echo ""
echo -e "Legend: ${YELLOW}*${NC}=dirty ${GREEN}+N${NC}=ahead ${RED}-N${NC}=behind ${GREEN}ok${NC}=clean"
