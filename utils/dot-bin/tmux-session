#!/usr/bin/env bash
# tmux-session — save and restore tmux sessions across reboots
#
# Usage:
#   tmux-session save     (prefix + Ctrl-s)
#   tmux-session restore  (prefix + Ctrl-r)

set -uo pipefail

SAVE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux"
SAVE_FILE="$SAVE_DIR/session.txt"
D=$'\t'

# ── Save ──────────────────────────────────────────────────────────────────────

save() {
    mkdir -p "$SAVE_DIR"
    # One line per pane: everything needed to recreate sessions, windows, panes, layouts
    tmux list-panes -a -F \
        "#{session_name}${D}#{window_index}${D}#{window_name}${D}#{window_layout}${D}#{window_active}${D}#{pane_index}${D}#{pane_current_path}${D}#{pane_active}" \
        > "$SAVE_FILE"
    tmux display-message "Saved $(wc -l < "$SAVE_FILE") panes"
}

# ── Restore ───────────────────────────────────────────────────────────────────

session_exists() { tmux has-session -t "=$1" 2>/dev/null; }
window_exists()  { tmux list-windows -t "$1" -F "#{window_index}" 2>/dev/null | grep -qx "$2"; }

restore() {
    [ -f "$SAVE_FILE" ] || { tmux display-message "No saved session found"; return 1; }

    local -A seen  # tracks session:win_idx → first pane already placed

    while IFS="$D" read -r session win_idx win_name layout win_active pane_idx pane_path pane_active; do
        local path="${pane_path/#\~/$HOME}"
        [ -d "$path" ] || path="$HOME"
        local key="${session}:${win_idx}"

        if [[ -z "${seen[$key]+x}" ]]; then
            seen[$key]=1
            if ! session_exists "$session"; then
                local base; base=$(tmux show -gv base-index 2>/dev/null || echo 1)
                TMUX= tmux new-session -d -s "$session" -n "$win_name" -c "$path" -x 220 -y 50
                # new-session creates the first window at base-index; move it if needed
                [[ "$base" != "$win_idx" ]] && \
                    tmux move-window -s "${session}:${base}" -t "${session}:${win_idx}" 2>/dev/null || true
            elif ! window_exists "$session" "$win_idx"; then
                tmux new-window -d -t "${session}:${win_idx}" -n "$win_name" -c "$path"
            fi
            # window already exists → its first pane is there, nothing to do
        else
            # Subsequent pane in the same window: split and shrink to make room
            tmux split-window -d -t "${session}:${win_idx}" -c "$path"
            tmux resize-pane  -t "${session}:${win_idx}" -U 999
        fi
    done < "$SAVE_FILE"

    # Second pass: apply layouts, focus active panes and windows
    local -A laid_out
    while IFS="$D" read -r session win_idx win_name layout win_active pane_idx pane_path pane_active; do
        local key="${session}:${win_idx}"
        if [[ -z "${laid_out[$key]+x}" ]]; then
            laid_out[$key]=1
            tmux select-layout -t "$key" "$layout" 2>/dev/null || true
        fi
        [[ "$pane_active" == "1" ]] && tmux select-pane   -t "${key}.${pane_idx}" 2>/dev/null || true
        [[ "$win_active"  == "1" ]] && tmux select-window -t "$key"               2>/dev/null || true
    done < "$SAVE_FILE"

    tmux display-message "Sessions restored"
}

case "${1:-}" in
    save)    save ;;
    restore) restore ;;
    *) printf "Usage: tmux-session {save|restore}\n" >&2; exit 1 ;;
esac
