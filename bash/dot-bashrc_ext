# Helper to append/prepend to PATH without duplicates
path_add() {
    if [ -d "$1" ] && [[ ":$PATH:" != *":$1:"* ]]; then
        if [ "$2" == "after" ]; then
            export PATH="$PATH:$1"
        else
            export PATH="$1:$PATH"
        fi
    fi
}

