    if command -v fd &>/dev/null; then
        fd -t f -i "$1"
    else
        find . -type f -iname "*$1*" 2>/dev/null
    fi
}
fdd() {
    if command -v fd &>/dev/null; then
        fd -t d -i "$1"
    else
        find . -type d -iname "*$1*" 2>/dev/null
    fi
}

# Find-and-replace a literal substring across any number of files, in place.
#   replace OLD NEW [path ...]         paths default to the current dir (recursive)
#   replace -n "OLD" "NEW" [path ...]  dry run — show files/lines, change nothing
#   replace "OLD" "NEW" -n [path ...]  -n is accepted anywhere in the arg list
#
# ripgrep locates the files that actually contain OLD (fast, honours .gitignore;
# falls back to grep -rl). The edit uses perl with \Q…\E so OLD and NEW are
# treated as plain text, not regex — no escaping of . * / $ & etc. NEW is read
# from the environment, so it can't be misread as a backreference. A sed
# fallback (with metachars escaped) covers the rare box without perl.
replace() {
    local dry=0
    # Separate -n/--dry-run from positional args — flag is accepted anywhere.
    local -a posargs=()
    for arg in "$@"; do
        case "$arg" in
            -n|--dry-run) dry=1 ;;
            *) posargs+=("$arg") ;;
        esac
    done
    if [ ${#posargs[@]} -lt 2 ]; then
        echo "Usage: replace [-n] OLD NEW [path ...]   (-n = dry run, accepted anywhere)"
        return 1
    fi
    local old="${posargs[0]}" new="${posargs[1]}"
    local -a paths=("${posargs[@]:2}"); [ ${#paths[@]} -eq 0 ] && paths=(.)

    # Collect the files that contain the literal substring.
    local -a files
    if command -v rg &>/dev/null; then
        mapfile -t files < <(rg -lF -- "$old" "${paths[@]}")
    else
        mapfile -t files < <(grep -rlF -- "$old" "${paths[@]}")
    fi
    if [ ${#files[@]} -eq 0 ]; then
        echo "No files contain: $old"
        return 1
    fi

    if [ "$dry" = 1 ]; then
        if command -v rg &>/dev/null; then
            rg -nF --color=auto -- "$old" "${files[@]}"
        else
            grep -nF -- "$old" "${files[@]}"
        fi
        printf '\n%d file(s) would be modified.\n' "${#files[@]}"
        return 0
    fi

    if command -v perl &>/dev/null; then
        OLD="$old" NEW="$new" perl -i -pe 's/\Q$ENV{OLD}\E/$ENV{NEW}/g' "${files[@]}"
    else
        # Escape regex metacharacters (pattern) and replacement specials for sed.
        # Write via temp file rather than `sed -i`: GNU wants `-i`, BSD/macOS
        # wants `-i ''`, but redirect + cat-back is identical on both — and
        # cat-ing into the original preserves its permissions and inode.
        local eo en f tmp
        eo=$(printf '%s' "$old" | sed -e 's/[][\\/.*^$]/\\&/g')
        en=$(printf '%s' "$new" | sed -e 's/[\\/&]/\\&/g')
        for f in "${files[@]}"; do
            tmp=$(mktemp) || return 1
            sed "s/$eo/$en/g" "$f" > "$tmp" && cat "$tmp" > "$f"
            command rm -f "$tmp"
        done
    fi
    printf 'Replaced in %d file(s).\n' "${#files[@]}"
}

# Serve current directory via HTTP
serve() {
    local port="${1:-8000}"
    echo "Serving $(pwd) on http://localhost:$port"
    python3 -m http.server "$port" 2>/dev/null || python -m SimpleHTTPServer "$port"
}

# Quick notes
note() {
    local f="$HOME/.notes"
    if [ -z "$1" ]; then
        [ -s "$f" ] && sed = "$f" | sed 'N;s/\n/ /' || echo "No notes yet."
    elif [ "$1" = "-c" ]; then
        if [ -z "$2" ]; then
            read -p "Clear all notes? (y/n) " ans
            [[ "$ans" == [yY]* ]] && rm -f "$f" && echo "Cleared"
        else
            sed -i "${2}d" "$f" && echo "Deleted #$2"
        fi
    else
        echo "$(date +'%F %H:%M'): $*" >> "$f" && echo "Added"
    fi
}

# Show most used commands
topcmd() {
    history | awk '{CMD[$2]++;count++;}END { for (a in CMD)print CMD[a] " " CMD[a]/count*100 "% " a;}' | grep -v "./" | sort -rn | head -20
}

ssh-ls() {
    printf "%-20s %-15s %-25s\n" "ALIAS" "USER" "HOSTNAME/IP"
    printf "%-20s %-15s %-25s\n" "-----" "----" "-----------"

    awk '
        # Reset and Print logic
        /^[Hh]ost / && $2 !~ /\*/ {
            if (alias) printf "%-20s %-15s %-25s\n", alias, user, host
            alias=$2; host="?"; user="-"
            next
        }
        # Case-insensitive matching for attributes
        tolower($1) == "hostname" { host=$2 }
        tolower($1) == "user"     { user=$2 }

        # Print the very last entry in the file
        END { if (alias) printf "%-20s %-15s %-25s\n", alias, user, host }
    ' ~/.ssh/config
}

ssh-go() {
    local host
    if command -v fzf &>/dev/null; then
        host=$(awk '/^[Hh]ost / && $2 !~ /\*/ {print $2}' ~/.ssh/config | fzf --height 40% --reverse --prompt="Select Host: ")
    else
        ssh-ls
        read -rp "Host: " host
    fi
    [ -n "$host" ] && ssh "$host"
}

ssh-save() {
    if [ "$#" -ne 2 ]; then
        echo "Usage: ssh-save user@host alias"
        return 1
    fi

    local input=$1
    local alias=$2
    local user host

    if [[ "$input" == *"@"* ]]; then
        user="${input%@*}"
        host="${input#*@}"
    else
        user=$USER
        host=$input
    fi

    # Ensure a newline before appending and keep EOF at start of line
    cat >> ~/.ssh/config <<EOF

Host $alias
    HostName $host
    User $user
EOF

    echo "Saved '$alias' ($user@$host) to ~/.ssh/config"
}

# Directory bookmarks (persistent)
MARKPATH="${MARKPATH:-$HOME/.marks}"
[ -d "$MARKPATH" ] || mkdir -p "$MARKPATH"

mark() {
    [ -z "$1" ] && echo "Usage: mark <name>" && return 1
    ln -sf "$(pwd)" "$MARKPATH/$1" && echo "Marked: $1 -> $(pwd)"
}

unmark() {
    [ -z "$1" ] && echo "Usage: unmark <name>" && return 1
    rm -f "$MARKPATH/$1" && echo "Removed: $1"
}

jump() {
    [ -z "$1" ] && echo "Usage: jump <name>" && return 1
    local target="$MARKPATH/$1"
    [ -L "$target" ] && cd -P "$target" || echo "Mark '$1' not found"
}

marks() { ls -l "$MARKPATH" 2>/dev/null | sed 's/  / /g' | cut -d' ' -f9- | sed 's/ -> / → /'; }

