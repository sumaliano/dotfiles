# ============================================================================
# FZF - Fuzzy finder integration (if available)
# ============================================================================

if command -v fzf &>/dev/null; then
    # Clipboard: WSL uses clip.exe, Linux uses xclip
    _fzf_clip='xclip -selection clipboard'
    grep -qi microsoft /proc/version 2>/dev/null && _fzf_clip='clip.exe'

    # FZF default options
    export FZF_DEFAULT_OPTS="
        --height=40%
        --layout=reverse
        --border=rounded
        --info=inline
        --prompt='❯ '
        --pointer='▶'
        --marker='✓'
        --bind='ctrl-a:select-all,ctrl-d:deselect-all'
        --bind='ctrl-y:execute-silent(echo {+} | $_fzf_clip)'
    "
    unset _fzf_clip

    # Use fd or rg for faster searches if available
    if command -v fd &>/dev/null; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
        export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
    elif command -v rg &>/dev/null; then
        export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git/*"'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    fi

    # Preview with bat if available
    if command -v bat &>/dev/null; then
        export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"
    fi

    # Keybindings + completion: Ctrl-T (files), Ctrl-R (history), Alt-C (cd).
    # The FZF_CTRL_T_* vars above only *configure* these widgets; this installs
    # them. fzf >= 0.48 emits its own bindings, so the vendored binary needs no
    # distro files. (Empty/error output on ancient fzf is a harmless no-op.)
    eval "$(fzf --bash 2>/dev/null)"

    # FZF-powered functions
    # Interactive cd with preview
    fcd() {
        local dir
        if command -v fd &>/dev/null; then
            dir=$(fd -t d . ${1:-.} 2>/dev/null | fzf --preview 'ls -la {}' +m) && cd "$dir"
        else
            dir=$(find ${1:-.} -type d 2>/dev/null | fzf --preview 'ls -la {}' +m) && cd "$dir"
        fi
    }

    # Interactive find-in-files: grep content, preview the hit, open it at the
    # matched line in $EDITOR. Pattern is optional ($1); empty browses all lines.
    fif() {
        command -v rg &>/dev/null || { echo "fif: needs ripgrep (rg)" >&2; return 1; }

        local INITIAL_QUERY="${1:-}"

        # We use fzf to dynamically rerun ripgrep on every keystroke.
        # {q} represents the exact string currently typed into fzf.
        IFS=: read -r file line _ < <(
            rg --line-number --no-heading --color=always --smart-case -- "${INITIAL_QUERY}" 2>/dev/null \
                | fzf --ansi \
                --disabled \
                --query "${INITIAL_QUERY}" \
                --bind "change:reload:sleep 0.1; rg --line-number --no-heading --color=always --smart-case -- {q} || true" \
                --delimiter : \
                --preview 'bat --color=always --style=numbers --highlight-line {2} --theme="Monokai Subliminal" {1} 2>/dev/null | rg --passthru --color=always --smart-case "{q}" 2>/dev/null' \
                --preview-window 'right:60%:+{2}-/2'
            )

            [ -n "$file" ] && "${EDITOR:-vi}" +"$line" "$file"
    }

    # Interactive history search (Cleaned up for different HISTTIMEFORMATs)
    fh() {
        local cmd
        cmd=$(history | fzf --tac --no-sort | sed 's/^[ ]*[0-9]*[ ]*//' | sed 's/^[0-9-]\{10\} [0-9:]\{8\}  //')
        [ -n "$cmd" ] && eval "$cmd"
    }

    # Interactive git log
    fgl() {
        git log --oneline --color=always | fzf --ansi --preview 'git show --color=always {1}' | cut -d' ' -f1
    }

    # Interactive git branch checkout
    fgb() {
        local branches branch
        branches=$(git branch --all | grep -v HEAD) &&
        branch=$(echo "$branches" | fzf -d $(( 2 + $(echo "$branches" | wc -l) )) +m) &&
        git checkout $(echo "$branch" | sed "s/.* //" | sed "s#remotes/[^/]*/##")
    }

    # Kill process interactively
    fkill() {
        local pid
        pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
        [ -n "$pid" ] && echo "$pid" | xargs kill -${1:-9}
    }

    # Fuzzy jump to bookmarks
    jb() {
        local dest
        dest=$(ls -1 "$MARKPATH" | fzf --prompt="Jump to mark: " --preview "ls -F --color=always $(readlink -f $MARKPATH/{})")
        [ -n "$dest" ] && jump "$dest"
    }

    # Fuzzy git status (stage/unstage files)
    fgs() {
        local files
        files=$(git status --porcelain | fzf -m --ansi --preview 'git diff --color=always {+2}' | awk '{print $2}')
        [ -n "$files" ] && git add $files
    }
fi

# ============================================================================
# TMUX - Session management
# ============================================================================

if command -v tmux &>/dev/null; then
    # Attach to existing session by name, or create it (defaults to basename of CWD)
    tat() {
        local name="${1:-$(basename "$(pwd)" | tr '.' '-')}"
        if tmux has-session -t "=$name" 2>/dev/null; then
            if [ -n "$TMUX" ]; then
                tmux switch-client -t "=$name"
            else
                tmux attach-session -t "=$name"
            fi
        else
            tmux new-session -s "$name"
        fi
    }

    alias tls='tmux list-sessions 2>/dev/null || echo "No tmux sessions"'
    alias tnew='tmux new-session -s'

    # Kill a session interactively
    tkill() {
        local session
        if command -v fzf &>/dev/null; then
            session=$(tmux list-sessions -F '#S' 2>/dev/null | fzf --prompt="Kill session: ")
        else
            tmux list-sessions 2>/dev/null
            read -rp "Kill session name: " session
        fi
        [ -n "$session" ] && tmux kill-session -t "$session"
    }

    # Switch session interactively (works inside or outside tmux)
    tsw() {
        local session
        if command -v fzf &>/dev/null; then
            session=$(tmux list-sessions -F '#S' 2>/dev/null | fzf --prompt="Switch to: ")
        else
            tmux list-sessions 2>/dev/null
            read -rp "Session name: " session
        fi
        if [ -n "$session" ]; then
            if [ -n "$TMUX" ]; then
                tmux switch-client -t "$session"
            else
                tmux attach-session -t "$session"
            fi
        fi
    }
fi

# ============================================================================
# WSL - Windows Subsystem for Linux
# ============================================================================

if grep -qi microsoft /proc/version 2>/dev/null; then
    alias pbcopy='clip.exe'
    alias pbpaste='powershell.exe -NoProfile Get-Clipboard 2>/dev/null | tr -d "\r"'
    alias clip=pbcopy

    # Open file/directory/URL with Windows default app
    open() {
        if [ -z "$1" ]; then
            explorer.exe . 2>/dev/null
        else
            local target
            target=$(wslpath -w "$1" 2>/dev/null) || target="$1"
            explorer.exe "$target" 2>/dev/null
            return 0
        fi
    }

    # Convert Linux path to Windows path
    alias winpath='wslpath -w'

    # Jump to Windows home directory
    winhome() {
        local winhome
        winhome=$(powershell.exe -NoProfile -Command '[Environment]::GetFolderPath("UserProfile")' 2>/dev/null | tr -d '\r')
        [ -n "$winhome" ] && cd "$(wslpath "$winhome")"
    }
fi

# ============================================================================
# COMPLETION - Better tab completion
# ============================================================================

# Enable programmable completion features
if ! shopt -oq posix; then
    [ -f /usr/share/bash-completion/bash_completion ] && source /usr/share/bash-completion/bash_completion
    [ -f /etc/bash_completion ] && source /etc/bash_completion
fi

# Git completion for aliases
if type __git_complete &>/dev/null; then
    __git_complete g __git_main
    __git_complete gco _git_checkout
    __git_complete gb _git_branch
    __git_complete gp _git_push
    __git_complete gpl _git_pull
fi

