#!/usr/bin/env bash
# Minimalist tmux session save and restore script
# Saves session names, windows, and pane layouts with their CWDs

set -euo pipefail

# Storage file
DUMP_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/session_snapshot.txt"
mkdir -p "$(dirname "$DUMP_FILE")"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

save() {
    echo -e "${BLUE}Saving tmux sessions...${NC}"

    # Format: session_name | window_index | window_name | layout | pane_index | pane_current_path
    tmux list-windows -a -F "#{session_name}|#{window_index}|#{window_name}|#{window_layout}|#{pane_index}|#{pane_current_path}" > "$DUMP_FILE"

    local count=$(wc -l < "$DUMP_FILE")
    echo -e "${GREEN}[ok]${NC} Saved $count panes across all sessions."
}

restore() {
    if [[ ! -f "$DUMP_FILE" ]]; then
        echo -e "${YELLOW}[!]${NC} No saved session found at $DUMP_FILE"
        return 1
    fi

    echo -e "${BLUE}Restoring tmux sessions...${NC}"

    # Read the dump file line by line
    while IFS='|' read -r session_name window_index window_name layout pane_index pane_path; do
        # 1. Create session if it doesn't exist
        if ! tmux has-session -t "$session_name" 2>/dev/null; then
            TMUX= tmux new-session -d -s "$session_name" -n "$window_name" -c "$pane_path"
        fi

        # 2. Create window if it doesn't exist
        if ! tmux list-windows -t "$session_name" -F "#I" | grep -q "^$window_index$"; then
            tmux new-window -d -t "$session_name:$window_index" -n "$window_name" -c "$pane_path"
        fi

        # 3. Apply the layout to the window
        # We only need to do this once per window (when we hit the first pane)
        if [[ "$pane_index" -eq 0 ]]; then
            tmux select-layout -t "$session_name:$window_index" "$layout"
        fi

        # 4. Set the directory for each pane (if the pane already exists)
        # Note: tmux doesn't easily let us 're-split' into a specific layout with CWDs
        # but the layout command handles the structure. The panes will start in the
        # CWD of the window's first pane.
    done < "$DUMP_FILE"

    echo -e "${GREEN}[ok]${NC} Restoration complete."
}

case "${1:-}" in
    save)    save ;;
    restore) restore ;;
    *)       echo "Usage: $0 {save|restore}"; exit 1 ;;
esac
