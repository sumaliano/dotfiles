#!/usr/bin/env bash
#
# Dotfiles Management CLI
# A simple wrapper for the dotfiles system.
#

set -euo pipefail

# Find project root (where install.sh is)
DOTFILES_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"

usage() {
    cat <<EOF
Usage: dot [COMMAND] [ARGS...]

Commands:
    sync         Run install.sh to re-link all components
    status       Show installation and power-up status
    edit         Open the dotfiles project in Neovim
    update       Pull latest changes and run sync
    check        Verify all dependencies and paths
    help         Show this message

Examples:
    dot sync vim bash
    dot edit
EOF
}

case "${1:-help}" in
    sync)
        shift
        bash "$DOTFILES_DIR/install.sh" "$@"
        ;;
    status)
        bash "$DOTFILES_DIR/install.sh" --status
        ;;
    edit)
        cd "$DOTFILES_DIR" && nvim .
        ;;
    update)
        cd "$DOTFILES_DIR"
        echo "Updating from Git..."
        git pull --rebase
        echo "Running Sync..."
        bash "$DOTFILES_DIR/install.sh"
        ;;
    check)
        echo "Dotfiles Root: $DOTFILES_DIR"
        echo "Installer: $([ -f "$DOTFILES_DIR/install.sh" ] && echo "FOUND" || echo "MISSING")"
        bash "$DOTFILES_DIR/install.sh" --status
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $1"
        usage
        exit 1
        ;;
esac
