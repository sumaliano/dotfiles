#!/usr/bin/env bash
#
# Dotfiles Installer - Portable & Robust
# Extends system configuration without replacing it.
#

set -euo pipefail

# ============================================================================
# UI Helpers
# ============================================================================

if [[ -t 1 ]] && [[ "${TERM:-dumb}" != "dumb" ]]; then
    RED='\033[0;31m' GREEN='\033[0;32m' BLUE='\033[0;34m' YELLOW='\033[1;33m' BOLD='\033[1m' NC='\033[0m'
else
    RED='' GREEN='' BLUE='' YELLOW='' BOLD='' NC=''
fi

info()    { echo -e "${BLUE}==>${NC} ${BOLD}$*${NC}"; }
success() { echo -e "${GREEN}[ok]${NC} $*"; }
warning() { echo -e "${YELLOW}[warn]${NC} $*"; }
error()   { echo -e "${RED}[err]${NC} $*" >&2; }

# ============================================================================
# Environment & Arguments
# ============================================================================

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=0
VERBOSE=0
UNINSTALL=0
CHECK_STATUS=0
COMPONENTS=()

usage() {
    cat <<EOF
Usage: $(basename "$0") COMMAND [OPTIONS] [COMPONENTS...]

Commands:
    sync             (Default) Link dotfiles to your home directory
    status           Check installation and power-up status
    update           Pull latest changes from git and re-install
    edit             Open the dotfiles project in $EDITOR
    clean            Remove dotfiles symlinks (Pure Cleanup)

Options:
    -n, --dry-run    Show changes without applying them
    -v, --verbose    Show detailed output
    -h, --help       Show this help

Components (for sync/clean):
    bash, vim, neovim, tmux, git, utils, fonts, inputrc

EOF
    exit 0
}

# Command Detection
COMMAND="help"
case "${1:-}" in
    sync|install|status|update|edit|clean|uninstall) COMMAND="$1"; shift ;;
    -*) COMMAND="sync" ;; # Flags without command imply sync
esac

# Normalize commands
[[ "$COMMAND" == "install" ]] && COMMAND="sync"
[[ "$COMMAND" == "uninstall" ]] && COMMAND="clean"

# Get Neovim config path once
NVIM_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"

while [[ $# -gt 0 ]]; do
    case $1 in
        -s|--status)    COMMAND="status"; shift ;;
        -n|--dry-run)   DRY_RUN=1; shift ;;
        -v|--verbose)   VERBOSE=1; shift ;;
        -u|--uninstall) COMMAND="clean"; shift ;;
        -h|--help)      usage ;;
        -*)             error "Unknown option: $1"; usage ;;
        *)              COMPONENTS+=("$1"); shift ;;
    esac
done

[[ ${#COMPONENTS[@]} -eq 0 ]] && COMPONENTS=(all)

# ============================================================================
# Core Functions
# ============================================================================

should_install() {
    local component="$1"
    [[ " ${COMPONENTS[*]} " =~ " all " ]] || [[ " ${COMPONENTS[*]} " =~ " $component " ]]
}

run() {
    if [[ $DRY_RUN -eq 1 ]]; then
        echo "  [dry-run] $*"
    else
        [[ $VERBOSE -eq 1 ]] && echo "  $*"
        "$@"
    fi
}

backup_and_link() {
    local src="$1"
    local dest="$2"

    [[ ! -e "$src" ]] && { warning "Source $src missing, skipping"; return 1; }

    # Handle existing destination
    if [[ -L "$dest" ]]; then
        run rm -f "$dest"
    elif [[ -e "$dest" ]]; then
        local backup="${dest}.backup.$(date +%Y%m%d_%H%M%S)"
        info "Backing up $dest to $backup"
        run mv "$dest" "$backup"
    fi

    # Ensure parent directory exists
    run mkdir -p "$(dirname "$dest")"

    # Use -n to treat dest as a normal file if it's a symlink to a directory
    run ln -sfn "$src" "$dest"
}

# ============================================================================
# Component Installers
# ============================================================================

install_bash() {
    info "Configuring Bash..."

    # Link dircolors
    [[ -f "$DOTFILES_DIR/_dir_colors" ]] && backup_and_link "$DOTFILES_DIR/_dir_colors" ~/.dir_colors

    if grep -q "# BEGIN DOTFILES" ~/.bashrc 2>/dev/null; then
        success "Bash extensions already present"
    else
        if [[ $DRY_RUN -eq 0 ]]; then
            cat >> ~/.bashrc <<EOF

# BEGIN DOTFILES
# Generated by dotfiles/install.sh - do not edit manually between markers
[ -f "$DOTFILES_DIR/_bashrc" ] && source "$DOTFILES_DIR/_bashrc"
# END DOTFILES
EOF
        fi
        success "Added source block to ~/.bashrc"
    fi

    # Always ensure local override template exists
    if [[ ! -f ~/.bashrc.local ]]; then
        if [[ $DRY_RUN -eq 0 ]]; then
            cat > ~/.bashrc.local <<EOF
# Local machine-specific overrides
# This file is ignored by git
EOF
        fi
        success "Created ~/.bashrc.local template"
    fi
}

install_vim() {
    info "Configuring Vim..."
    backup_and_link "$DOTFILES_DIR/_vimrc" ~/.vimrc

    # Link the full _vim directory if it exists (for spell files, etc.)
    if [[ -d "$DOTFILES_DIR/_vim" ]]; then
        backup_and_link "$DOTFILES_DIR/_vim" ~/.vim
    fi

    # Ensure data directories exist
    run mkdir -p ~/.vim/{undo,backup,swap}

    # Link the colors directory directly from Neovim config
    if [[ -d "$DOTFILES_DIR/_config/nvim/colors" ]]; then
        backup_and_link "$DOTFILES_DIR/_config/nvim/colors" ~/.vim/colors
    fi
    success "Vim configured"
}

install_neovim() {
    info "Configuring Neovim..."
    local nvim_conf="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"

    # Link the whole directory
    backup_and_link "$DOTFILES_DIR/_config/nvim" "$nvim_conf"

    success "Neovim configured"
}

install_tmux() {
    info "Configuring Tmux..."
    backup_and_link "$DOTFILES_DIR/_tmuxrc" ~/.tmux.conf
    success "Tmux configured"
}

install_git() {
    info "Configuring Git..."

    # Link global gitignore
    [[ -f "$DOTFILES_DIR/_gitignore_global" ]] && backup_and_link "$DOTFILES_DIR/_gitignore_global" ~/.gitignore_global

    if [[ -f ~/.gitconfig ]] && ! grep -q "Git configuration template" ~/.gitconfig 2>/dev/null; then
        warning "~/.gitconfig exists and isn't a dotfiles template. Skipping."
        info "Manual merge: cat $DOTFILES_DIR/_gitconfig >> ~/.gitconfig"
    else
        run cp "$DOTFILES_DIR/_gitconfig" ~/.gitconfig
        success "Git config installed (Remember: git config --global user.email '...') "
    fi
}

install_fonts() {
    info "Installing Fonts..."
    local font_dir="$HOME/.local/share/fonts/dotfiles"
    if [[ -d "$DOTFILES_DIR/_fonts" ]]; then
        backup_and_link "$DOTFILES_DIR/_fonts" "$font_dir"
        if command -v fc-cache &>/dev/null; then
            run fc-cache -f
            success "Fonts installed and cache refreshed"
        else
            warning "fc-cache not found. Fonts linked but system might not see them."
        fi
    else
        warning "No _fonts directory found"
    fi
}

install_utils() {
    info "Installing Utilities..."
    backup_and_link "$DOTFILES_DIR/_bin" ~/.bin
    run chmod +x "$DOTFILES_DIR/_bin"/* 2>/dev/null || true
    success "Utilities linked to ~/.bin"
}

install_inputrc() {
    info "Configuring Inputrc..."
    backup_and_link "$DOTFILES_DIR/_inputrc" ~/.inputrc
    success "Inputrc configured"
}

# ============================================================================
# Uninstaller (Pure Cleanup)
# ============================================================================

do_clean() {
    info "Cleaning up dotfiles (Pure Cleanup)..."

    # 1. Bash Removal
    if [[ $DRY_RUN -eq 0 ]]; then
        sed -i '/# BEGIN DOTFILES/,/# END DOTFILES/d' ~/.bashrc 2>/dev/null || true
    fi

    # 2. Git Config Cleanup (Only if it's our template)
    if [[ -f ~/.gitconfig ]] && grep -q "Git configuration template" ~/.gitconfig 2>/dev/null; then
        run rm ~/.gitconfig
        success "Removed ~/.gitconfig (template)"
    fi

    # 3. Local Template Cleanup (Only if unedited)
    if [[ -f ~/.bashrc.local ]]; then
        if grep -q "Local machine-specific overrides" ~/.bashrc.local && [[ $(wc -l < ~/.bashrc.local) -le 3 ]]; then
            run rm ~/.bashrc.local
            success "Removed unedited ~/.bashrc.local"
        fi
    fi

    # 4. Symlink Removal
    local links=(~/.vimrc ~/.vim ~/.tmux.conf ~/.inputrc ~/.dir_colors ~/.bin "$NVIM_CONF" ~/.local/share/fonts/dotfiles ~/.gitignore_global)
    for l in "${links[@]}"; do
        if [[ -L "$l" ]]; then
            run rm "$l"
            success "Removed $l"
        fi
    done

    # 5. System Refresh
    if command -v fc-cache &>/dev/null; then
        run fc-cache -f
    fi

    info "Cleanup complete. Original files (marked .backup.*) were left untouched."
}

# ============================================================================
# Status Check
# ============================================================================

do_status() {
    echo -e "${BLUE}${BOLD}Installation Status:${NC}\n"

    local components=(
        "Bash Block    :~/.bashrc:grep -q '# BEGIN DOTFILES' ~/.bashrc"
        "Inputrc       :~/.inputrc:[ -L ~/.inputrc ]"
        "Tmux          :~/.tmux.conf:[ -L ~/.tmux.conf ]"
        "Vim Config    :~/.vimrc:[ -L ~/.vimrc ]"
        "Vim Dir       :~/.vim:[ -L ~/.vim ]"
        "Neovim        :$NVIM_CONF:[ -L \"$NVIM_CONF\" ]"
        "Utilities     :~/.bin:[ -L ~/.bin ]"
        "Fonts         :~/.local/share/fonts/dotfiles:[ -L ~/.local/share/fonts/dotfiles ]"
        "Git Config    :~/.gitconfig:grep -q 'Git configuration template' ~/.gitconfig"
        "Git Global Ign:~/.gitignore_global:[ -L ~/.gitignore_global ]"
    )

    for c in "${components[@]}"; do
        local name="${c%%:*}"
        local path="${c#*:}"
        path="${path%%:*}"
        local cmd="${c##*:}"

        if eval "$cmd" 2>/dev/null; then
            printf "  ${GREEN}[Installed]${NC} %-15s (%s)\n" "$name" "$path"
        else
            printf "  ${RED}[Missing]  ${NC} %-15s (%s)\n" "$name" "$path"
        fi
    done

    check_powerups
}

# ============================================================================
# Validation & Summary
# ============================================================================

check_powerups() {
    echo -e "\n${BOLD}Scanning for Power-up Tools:${NC}"
    local tools=(fzf rg fd bat eza htop)
    for t in "${tools[@]}"; do
        if command -v "$t" &>/dev/null; then
            echo -e "  ${GREEN}[ok]${NC} $t"
        else
            echo -e "  ${RED}[  ]${NC} $t (Not found)"
        fi
    done
}

# ============================================================================
# Main
# ============================================================================

main() {
    if [[ "$COMMAND" == "help" ]]; then
        usage
    fi

    if [[ "$COMMAND" == "status" ]]; then
        do_status
        exit 0
    fi

    if [[ "$COMMAND" == "clean" ]]; then
        do_clean
        exit 0
    fi

    if [[ "$COMMAND" == "update" ]]; then
        info "Updating dotfiles..."
        cd "$DOTFILES_DIR"
        git pull --rebase
        info "Running re-sync..."
        COMMAND="sync"
        main
        exit 0
    fi

    if [[ "$COMMAND" == "edit" ]]; then
        cd "$DOTFILES_DIR"
        exec "${EDITOR:-vi}" .
    fi

    echo -e "${BLUE}${BOLD}Dotfiles Sync${NC}"
    [[ $DRY_RUN -eq 1 ]] && echo -e "${YELLOW}DRY RUN MODE${NC}\n"

    should_install bash    && install_bash
    should_install vim     && install_vim
    should_install neovim  && install_neovim
    should_install tmux    && install_tmux
    should_install git     && install_git
    should_install fonts   && install_fonts
    should_install utils   && install_utils
    should_install inputrc && install_inputrc

    success "Sync finished!"
    check_powerups

    echo -e "\n${BOLD}Next Step:${NC} Run 'source ~/.bashrc' or restart your terminal."
}

main
