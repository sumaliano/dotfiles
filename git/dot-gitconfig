# Shared git configuration — layered into ~/.gitconfig via [include].
# Your identity and credentials stay in your own ~/.gitconfig; this file holds
# the portable settings (pager, aliases, diff/merge tools, colors).
#
# Wired automatically by `make git`. Manual setup:
#   git config --global --add include.path ~/dotfiles/git/dot-gitconfig

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    # Use delta when it's on PATH, otherwise fall back to less.
    # `command -v` is evaluated by the shell git runs the pager through,
    # so this degrades gracefully on machines without delta installed.
    # Quoted because git treats ';' and '#' as comment starts in bare values.
    pager = "if command -v delta >/dev/null 2>&1; then delta; else less -FRX; fi"
    autocrlf = input
    whitespace = trailing-space,space-before-tab

[interactive]
    # Used by `git add -p` etc. Pass through unchanged when delta is absent.
    diffFilter = "if command -v delta >/dev/null 2>&1; then delta --color-only; else cat; fi"

# Applied only when delta actually runs; ignored harmlessly otherwise.
[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    hyperlinks = false

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[diff]
    tool = nvimdiff
    colorMoved = default
    algorithm = histogram

[difftool "nvimdiff"]
    # -d starts nvim in diff mode
    cmd = nvim -d "$LOCAL" "$REMOTE"

[difftool]
    prompt = false

[merge]
    tool = nvim4
    conflictstyle = diff3

[mergetool "nvim3"]
    # 3-way: LOCAL | MERGED | REMOTE
    cmd = nvim -d "$LOCAL" "$MERGED" "$REMOTE" -c "wincmd l"
    trustExitCode = true

[mergetool "nvim4"]
    # 4-way: LOCAL | BASE | REMOTE (top)
    #        MERGED (bottom)
    cmd = nvim -d "$LOCAL" "$BASE" "$REMOTE" "$MERGED" -c "wincmd J"
    trustExitCode = true

[mergetool]
    prompt = false

[rerere]
    enabled = true

[alias]
    # Undo
    undo = reset HEAD~1 --mixed
    unstage = reset HEAD --
    discard = checkout --

    # Utility
    whoami = !git config user.name && git config user.email

    # Find
    find = !git ls-files | grep -i
    grep = grep -Ii

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = green
    changed = yellow
    untracked = red

[help]
    autocorrect = 20

[credential]
    helper = cache --timeout=3600

